# Database
# Local development: Use local PostgreSQL
# Railway: Set this in Railway dashboard (auto-provided when you add PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/midterms2026

# FEC API
FEC_API_KEY=your_fec_api_key_here
FEC_API_BASE_URL=https://api.open.fec.gov/v1

# Chat (Gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Server
PORT=3001
NODE_ENV=development

# Rate Limiting
FEC_API_MAX_REQUESTS_PER_HOUR=120
