# API Keys - Template file for environment variables
# Copy this file to .env and fill in your actual values

# Backend API URL
# Development: http://localhost:3001
# Production: https://your-backend-url.railway.app
VITE_API_URL=http://localhost:3001

# Database (if needed)
# VITE_DATABASE_URL=your_database_url_here

# Authentication (if needed)
# VITE_AUTH_SECRET=your_auth_secret_here

# Third-party services (if needed)
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key_here
# VITE_STRIPE_PUBLIC_KEY=your_stripe_key_here
# VITE_FIREBASE_API_KEY=your_firebase_key_here

# Other configuration
# VITE_APP_ENV=development
